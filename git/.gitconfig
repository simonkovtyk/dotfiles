[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[user]
	name = Simon
	email = simon@kovtyk.com
	signingkey = 209C090BDEC066F4
[safe]
	directory = /home/simonkov
[credential]
	helper = libsecret
[commit]
	gpgSign = true
[pull]
	rebase = false
[push]
	autoSetupRemote = true
[core]
	editor = helix
[tag]
	gpgSign = true
[init]
	defaultBranch = main
